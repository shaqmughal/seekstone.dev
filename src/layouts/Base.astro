---
/**
 * Base layout — self-hosted fonts + the seekstone-design system, the document
 * shell, and the website motion layer. The <head> here is the SEO seam (SHA-112).
 */
// Self-hosted fonts (Fontsource) — privacy-first, no Google Fonts CDN (SHA-114/115).
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/inter/800.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "@fontsource/jetbrains-mono/600.css";
import "@fontsource/jetbrains-mono/700.css";
// Design system: tokens (order matters) then base reset, then website layout.
import "../styles/ds/colors.css";
import "../styles/ds/typography.css";
import "../styles/ds/spacing.css";
import "../styles/ds/effects.css";
import "../styles/ds/base.css";
import "../styles/site.css";
import { SITE } from "../consts";

interface Props {
	title?: string;
	description?: string;
	/** Open Graph object type. "website" for the landing page, "article" for docs/changelog. */
	ogType?: string;
	/** Social card path, resolved to an absolute URL. Defaults to the site OG image. */
	ogImage?: string;
	/** JSON-LD schema object(s) to emit in <head>. The landing page passes
	 *  SoftwareApplication (SHA-112); FAQPage is appended here in SHA-113. */
	jsonLd?: object | object[];
}

const {
	title = SITE.title,
	description = SITE.description,
	ogType = "website",
	ogImage = SITE.ogImage,
	jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
const schemas = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />

		<!-- Open Graph (Facebook, LinkedIn, Slack, iMessage, Discord) -->
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content={SITE.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter / X large summary card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		{/* JSON-LD structured data — the GEO play. set:html keeps the JSON
		    intact (Astro would otherwise HTML-escape quotes and break it). */}
		{
			schemas.map((schema) => (
				<script type="application/ld+json" set:html={JSON.stringify(schema)} />
			))
		}

		{/* Plausible — cookieless, privacy-first analytics (SHA-115). Dormant
		    until the seekstone.dev site is created at plausible.io and the
		    domain is live: the script ignores localhost and only counts the
		    domain named in data-domain. The stub queues plausible() calls made
		    before the external script finishes loading. */}
		<script defer data-domain={SITE.domain} src="https://plausible.io/js/script.js"></script>
		<script is:inline>
			window.plausible =
				window.plausible ||
				function () {
					(window.plausible.q = window.plausible.q || []).push(arguments);
				};
		</script>
		<slot name="head" />
	</head>
	<body>
		<div class="ss-site">
			<slot />
		</div>
		<!-- Motion layer: ambient aurora, scroll reveals, count-up, hero parallax, card spotlight.
		     Loaded as a classic end-of-body script (NOT defer): anim.js calls onReady()
		     before it defines its selector list, so it must run while readyState is still
		     "loading" — defer makes onReady fire init() too early and it throws. -->
		<script is:inline src="/scripts/anim.js"></script>
		{/* Conversion tracking (SHA-115): one delegated listener fires a Plausible
		    custom event for any clicked element carrying data-analytics — copy
		    buttons, GitHub/npm links, etc. Declarative: the event name lives on
		    the element, not in here. */}
		<script>
			const w = window as unknown as { plausible?: (event: string) => void };
			document.addEventListener("click", (e) => {
				const el = (e.target as HTMLElement).closest<HTMLElement>("[data-analytics]");
				const event = el?.dataset.analytics;
				if (event) w.plausible?.(event);
			});
		</script>
	</body>
</html>
