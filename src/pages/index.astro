---
/**
 * Landing page — the full Seekstone marketing site, ported from the
 * seekstone-design UI kit to Astro (zero framework runtime; interactivity via
 * small vanilla islands). Copy and every figure trace to the README.
 */
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Benchmark from "../components/Benchmark.astro";
import Tools from "../components/Tools.astro";
import Pillars from "../components/Pillars.astro";
import Install from "../components/Install.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../consts";
import { FAQS } from "../data/faq";

// SoftwareApplication schema (SHA-112) — the primary GEO signal. Tells Google
// rich results and AI citation engines what Seekstone is, that it's free, and
// where to get it. Sourced from SITE so version/URLs never drift.
const softwareApplication = {
	"@context": "https://schema.org",
	"@type": "SoftwareApplication",
	name: SITE.name,
	description: SITE.description,
	applicationCategory: "DeveloperApplication",
	operatingSystem: "macOS, Linux, Windows",
	offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
	url: SITE.url,
	downloadUrl: SITE.npm,
	softwareVersion: SITE.version,
	license: "https://opensource.org/licenses/MIT",
	author: { "@type": "Person", name: SITE.author.name, url: SITE.author.url },
};

// FAQPage schema (SHA-113) — built from the SAME FAQS array the visible
// accordion renders, so the structured data is guaranteed to match the page.
// High-leverage GEO win: AI engines pull individual Q&A answers directly.
const faqPage = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: FAQS.map(({ q, a }) => ({
		"@type": "Question",
		name: q,
		acceptedAnswer: { "@type": "Answer", text: a },
	})),
};
---

<Base jsonLd={[softwareApplication, faqPage]}>
	<Nav />
	<main>
		<Hero />
		<Benchmark />
		<Tools />
		<Pillars />
		<Install />
		<Faq />
	</main>
	<Footer />
</Base>
