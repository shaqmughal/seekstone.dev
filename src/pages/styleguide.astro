---
/**
 * Internal design-system reference (SHA-104). Renders the tokens so they can
 * be reviewed on the Vercel preview. noindex'd — this is not a public page.
 */
import Base from "../layouts/Base.astro";

const purples = [
	["--purple-100", "#b8a6ff"],
	["--purple-200", "#9a7dff"],
	["--purple-300", "#7c5cff"],
	["--purple-400", "#6344e0"],
	["--purple-500", "#4c2fb8"],
	["--purple-900", "#2a2350"],
	["--amber", "#f59e0b"],
];

const type = [
	["--text-4xl", "Display"],
	["--text-2xl", "Section heading"],
	["--text-xl", "Subheading"],
	["--text-base", "Body copy"],
	["--text-sm", "Small / captions"],
];
---

<Base title="Seekstone — Design System">
	<meta name="robots" content="noindex" slot="head" />
	<main class="container" style="padding-block: var(--space-16);">
		<p class="eyebrow">Internal · SHA-104</p>
		<h1>Design system</h1>
		<p style="color: var(--fg-muted);">
			Dark-mode-first, monospace accents. Palette derived from the brand mark.
		</p>

		<section style="margin-top: var(--space-12);">
			<h2>Color</h2>
			<div class="swatches">
				{
					purples.map(([token, hex]) => (
						<div class="swatch">
							<div class="swatch__chip" style={`background: var(${token});`} />
							<code>{token}</code>
							<code style="color: var(--fg-subtle);">{hex}</code>
						</div>
					))
				}
			</div>
		</section>

		<section style="margin-top: var(--space-12);">
			<h2>Typography</h2>
			{
				type.map(([token, label]) => (
					<p style={`font-size: var(${token}); margin-bottom: var(--space-2);`}>
						{label} <code style="color: var(--fg-subtle);">{token}</code>
					</p>
				))
			}
		</section>

		<section style="margin-top: var(--space-12);">
			<h2>Components</h2>
			<div style="display: flex; gap: var(--space-4); flex-wrap: wrap; align-items: center;">
				<button class="btn btn--primary">Primary action</button>
				<button class="btn btn--ghost">Secondary</button>
				<code class="card mono" style="padding: var(--space-3) var(--space-4);">npx seekstone init</code>
			</div>
			<div class="card" style="margin-top: var(--space-6); max-width: 32rem;">
				<p class="eyebrow">Card</p>
				<p style="margin: 0; color: var(--fg-muted);">
					Elevated surface for tool cards, benchmark rows, and FAQ items.
				</p>
			</div>
		</section>
	</main>
</Base>

<style>
	.swatches {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
		gap: var(--space-4);
	}
	.swatch {
		display: flex;
		flex-direction: column;
		gap: var(--space-1);
		font-size: var(--text-xs);
	}
	.swatch__chip {
		height: 56px;
		border-radius: var(--radius);
		border: 1px solid var(--border);
	}
</style>
